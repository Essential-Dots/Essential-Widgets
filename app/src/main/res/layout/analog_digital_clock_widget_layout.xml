<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/analog_digital_clock_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_2x2_background">

    <!-- Decorative SVG border — tinted via setColorFilter in code -->
    <ImageView
        android:id="@+id/analog_digital_clock_widget_border"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/ic_square_clock_border"
        android:scaleType="fitXY"
        android:padding="8dp"/>

    <!-- Clock bitmap centered -->
    <ImageView
        android:id="@+id/analog_digital_clock_widget_canvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter" />

</FrameLayout>