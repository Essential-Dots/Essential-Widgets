<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Radial glow background behind the header -->
    <View
        android:id="@+id/header_glow"
        android:layout_width="600dp"
        android:layout_height="400dp"
        android:layout_gravity="top|center"
        android:alpha="0.7"
        android:background="@drawable/header_glow" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/dot_pattern"
        android:alpha="0.2" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header: Title + Subtitle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="152dp"
                android:paddingBottom="96dp">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Essential Widgets"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:fontFamily="@font/serif_regular"
                    android:includeFontPadding="false"
                    android:textColor="@color/top"/>

                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="BY COMMUNITY FOR COMMUNITY"
                    android:textColor="@color/top"
                    android:textSize="12dp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/dots_regular" />

            </LinearLayout>

            <!-- Search Bar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/foreground_40"
                app:strokeWidth="0.2dp"
                app:cardBackgroundColor="@color/background_60">

                <LinearLayout

                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:cardBackgroundColor="@color/background_60">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/white"
                        app:cardBackgroundColor="@color/background_60"/>

                    <EditText
                        android:id="@+id/et_search"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:inputType="text"
                        android:maxLines="1"
                        android:imeOptions="actionSearch"
                        app:cardBackgroundColor="@color/foreground_40"
                        android:background="@android:color/transparent"
                        android:backgroundTint="@android:color/transparent"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Widget Grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_widgets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="100dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>