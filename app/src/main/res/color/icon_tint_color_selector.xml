<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State when the icon is active/checked -->
    <item android:state_checked="true" android:color="@color/n_red" />
    <!-- State when the icon is selected -->
    <item android:state_selected="true" android:color="@color/n_red" />
    <!-- Default state (inactive/unchecked) -->
    <item android:color="@color/n_gray" />
</selector>
